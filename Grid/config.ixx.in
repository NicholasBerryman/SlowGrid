module;
#include <cstdint>
#include <type_traits>
#define COORDINATE_T ${COORDINATE_T}
#define FLOAT_DISTANCE_T ${FLOAT_DISTANCE_T}
export module SG_GridConfigs;

export namespace SG_Grid {
    typedef std::make_unsigned_t<COORDINATE_T> u_coordinate_t;
    typedef COORDINATE_T coordinate_t;
    typedef FLOAT_DISTANCE_T float_distance_t;

    static_assert(std::is_signed_v<coordinate_t>, "Coordinate type must be signed (an unsigned version will also be created, named 'u_coordinate_t')");
}
